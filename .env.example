# Server listen address (default: 0.0.0.0:8080)
# LISTEN_ADDR=0.0.0.0:8080

# Set one or more sport team variables (comma-separated ESPN abbreviations).
# At least one must be set for the plugin to return data.

# NFL
# NFL_TEAMS=PHI,DAL,KC

# NBA
# NBA_TEAMS=LAL,BOS

# MLB
# MLB_TEAMS=NYY,LAD

# NHL
# NHL_TEAMS=NYR,BOS

# College Football
# NCAAF_TEAMS=MICH,OSU

# College Basketball
# NCAAM_TEAMS=DUKE,UNC

# MLS
# MLS_TEAMS=ATL,LAFC

# English Premier League
# EPL_TEAMS=LIV,ARS

# UFC / MMA
# UFC_FIGHTERS=

# Racing — set to true to enable (no team selection needed)
# IndyCar
# INDYCAR=true

# NASCAR Cup Series
# NASCAR=true

# NASCAR Xfinity Series
# NASCAR_XFINITY=true

# NASCAR Truck Series
# NASCAR_TRUCK=true

# Formula 1
# F1=true

# Timezone for displaying game times (IANA format, e.g. America/New_York, America/Chicago, America/Los_Angeles)
# Defaults to UTC if not set.
# TIMEZONE=America/New_York